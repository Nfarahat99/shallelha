# ============================================================
# Sha'lelha — Environment Variable Template
# Copy this to .env and fill in real values.
# NEVER commit .env to git.
# ============================================================

# --- apps/server (Railway Node.js service) ---

# PostgreSQL — use Railway reference variable in Railway dashboard:
# ${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql://user:password@host:5432/shallelha

# Redis — use Railway private URL with ?family=0 suffix:
# ${{Redis.REDIS_PRIVATE_URL}}?family=0
# The ?family=0 suffix is REQUIRED for Railway IPv6 DNS resolution.
REDIS_URL=redis://default:password@host:6379?family=0

# The public URL of the Vercel frontend (set after Vercel deploy):
FRONTEND_URL=https://shallelha.vercel.app

# Railway sets PORT automatically — 4000 is the local dev default:
PORT=4000

NODE_ENV=development

# --- apps/web (Vercel) ---

# The public Railway backend URL (set after Railway deploy):
NEXT_PUBLIC_BACKEND_URL=https://shallelha-server.up.railway.app
