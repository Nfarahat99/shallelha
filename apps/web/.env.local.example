# Sha'lelha frontend environment variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git — it is gitignored by Next.js scaffold.

# The Railway backend public URL — set after Plan 01 Railway deployment.
# Must include https:// and NO trailing slash.
NEXT_PUBLIC_BACKEND_URL=https://your-railway-service.up.railway.app

# NextAuth.js v5 — required for host authentication
# Generate AUTH_SECRET: npx auth secret
AUTH_SECRET=your-secret-here

# Google OAuth — from Google Cloud Console → Credentials → OAuth 2.0 Client IDs
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# Resend — magic link email (from resend.com dashboard)
AUTH_RESEND_KEY=re_your_api_key

# PostgreSQL PUBLIC URL — needed so NextAuth Prisma adapter can reach Railway DB from Vercel.
# In Railway: Postgres service → Settings → Networking → Enable TCP Proxy → copy the public URL
# Format: postgresql://postgres:<password>@<proxy-host>:<port>/railway
DATABASE_URL=postgresql://postgres:password@host:port/railway
