# ─────────────────────────────────────────────────────────────────────────────
# Sha'lelha — Web App Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local or any file containing real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Socket / Backend ──────────────────────────────────────────────────────────

# Backend Socket.io / API URL (public — exposed to browser via NEXT_PUBLIC_)
# In production: https://your-server.up.railway.app
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000

# ── Authentication (Auth.js / NextAuth) ───────────────────────────────────────

# Google OAuth credentials — create at https://console.developers.google.com
AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-client-secret

# Auth.js secret — generate with: openssl rand -base64 32
AUTH_SECRET=change-me-to-a-random-secret-32-chars-minimum

# ── Admin Dashboard ───────────────────────────────────────────────────────────

# Password required to log in to /admin
ADMIN_PASSWORD=change-me-in-production

# Session token set in the admin cookie — must match ADMIN_PASSWORD check
# Generate with: openssl rand -hex 32
ADMIN_SESSION_TOKEN=change-me-to-a-random-hex-token

# ── Cloudinary (question image uploads) ──────────────────────────────────────

CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ── Database (Prisma — web app reads questions/categories) ────────────────────

DATABASE_URL=postgresql://user:password@localhost:5432/shallelha

# ── Node Environment ──────────────────────────────────────────────────────────

NODE_ENV=development
