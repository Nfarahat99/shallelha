# ─────────────────────────────────────────────────────────────────────────────
# Sha'lelha — Server Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env or any file containing real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────

# Port the Express/Socket.io server listens on
PORT=4000

# ── Database ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string
# In production: provided by Railway as a secret variable
DATABASE_URL=postgresql://user:password@localhost:5432/shallelha

# ── Redis ─────────────────────────────────────────────────────────────────────

# Redis connection string
# In production: provided by Railway Redis add-on
REDIS_URL=redis://localhost:6379

# ── CORS ──────────────────────────────────────────────────────────────────────

# Frontend URL allowed by CORS — must exactly match the deployed web app origin
# In production: https://your-app.vercel.app
FRONTEND_URL=http://localhost:3000

# ── Node Environment ──────────────────────────────────────────────────────────

NODE_ENV=development
